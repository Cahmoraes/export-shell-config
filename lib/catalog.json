{
  "_comment": "Base de conhecimento de como instalar cada ferramenta em cada SO. Adicionar uma ferramenta = adicionar uma entrada aqui. 'detect' = nome do binário procurado com 'which'. 'install' = comando por plataforma (macos/debian/cargo/all).",

  "cli_tools": {
    "zoxide": {
      "describe": "cd inteligente baseado em frequência",
      "detect": "zoxide",
      "source": "https://github.com/ajeetdsouza/zoxide",
      "verify": "zoxide --version",
      "install": {
        "macos": "brew install zoxide",
        "debian": "sudo apt install -y zoxide",
        "fallback": "curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh"
      },
      "shell_init": "eval \"$(zoxide init zsh)\""
    },
    "fzf": {
      "describe": "fuzzy finder de linha de comando",
      "detect": "fzf",
      "source": "https://github.com/junegunn/fzf",
      "verify": "fzf --version",
      "install": {
        "macos": "brew install fzf",
        "debian": "sudo apt install -y fzf",
        "fallback": "git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf && ~/.fzf/install --all"
      },
      "shell_init": "[[ -f \"$HOME/.fzf.zsh\" ]] && source \"$HOME/.fzf.zsh\""
    },
    "bat": {
      "describe": "cat com syntax highlighting",
      "detect": "bat",
      "detect_alt": "batcat",
      "source": "https://github.com/sharkdp/bat",
      "verify": "bat --version || batcat --version",
      "install": {
        "macos": "brew install bat",
        "debian": "sudo apt install -y bat"
      },
      "note": "No Debian/Ubuntu o binário se chama 'batcat' (conflito de nome). Por isso seu .zshrc tem `alias bat=\"batcat\"`. No macOS o binário JÁ se chama 'bat' — esse alias deve ser REMOVIDO, senão quebra o comando."
    },
    "fd": {
      "describe": "find amigável e rápido",
      "detect": "fd",
      "detect_alt": "fdfind",
      "source": "https://github.com/sharkdp/fd",
      "verify": "fd --version || fdfind --version",
      "install": {
        "macos": "brew install fd",
        "debian": "sudo apt install -y fd-find"
      },
      "note": "No Debian/Ubuntu o binário se chama 'fdfind'. Daí o `alias fd=\"fdfind\"` no seu .zshrc. No macOS é 'fd' nativo — remover o alias."
    },
    "eza": {
      "describe": "ls moderno (substitui exa)",
      "detect": "eza",
      "source": "https://github.com/eza-community/eza",
      "verify": "eza --version",
      "install": {
        "macos": "brew install eza",
        "debian": "sudo apt install -y eza",
        "fallback": "cargo install eza"
      },
      "note": "eza em apt só existe em distros recentes; se falhar, use cargo."
    },
    "glow": {
      "describe": "renderizador de markdown no terminal",
      "detect": "glow",
      "source": "https://github.com/charmbracelet/glow",
      "verify": "glow --version",
      "install": {
        "macos": "brew install glow",
        "debian": "sudo mkdir -p /etc/apt/keyrings && curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg && echo \"deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *\" | sudo tee /etc/apt/sources.list.d/charm.list && sudo apt update && sudo apt install -y glow"
      }
    },
    "micro": {
      "describe": "editor de terminal moderno",
      "detect": "micro",
      "source": "https://github.com/zyedidia/micro",
      "verify": "micro --version",
      "install": {
        "macos": "brew install micro",
        "debian": "sudo apt install -y micro",
        "fallback": "cd ~/.local/bin && curl https://getmic.ro | bash"
      },
      "config_dirs": ["~/.config/micro"]
    },
    "starship": {
      "describe": "prompt cross-shell (opcional; você usa OMZ theme hoje)",
      "detect": "starship",
      "source": "https://github.com/starship/starship",
      "verify": "starship --version",
      "install": {
        "macos": "brew install starship",
        "debian": "curl -sS https://starship.rs/install.sh | sh"
      },
      "config_dirs": ["~/.config/starship.toml"]
    },
    "kubectl": {
      "describe": "CLI do Kubernetes",
      "detect": "kubectl",
      "source": "https://kubernetes.io/docs/tasks/tools/",
      "verify": "kubectl version --client",
      "install": {
        "macos": "brew install kubectl",
        "debian": "sudo apt install -y kubectl || (curl -LO \"https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl\" && sudo install -m 0755 kubectl /usr/local/bin/kubectl)"
      }
    },
    "rtk": {
      "describe": "proxy CLI para Claude Code — filtra saída e reduz consumo de tokens (60-90%)",
      "detect": "rtk",
      "source": "https://github.com/rtk-ai/rtk",
      "verify": "rtk --version",
      "install": {
        "fallback": "curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/main/install.sh | bash"
      },
      "note": "Instala em ~/.local/bin/rtk. Cuidado com colisão de nome: 'reachingforthejack/rtk' (Rust Type Kit) usa o mesmo binário. Verifique com `rtk gain` após instalar — se falhar, é o errado."
    }
  },

  "omz_plugins": {
    "zsh-autosuggestions": {
      "source": "https://github.com/zsh-users/zsh-autosuggestions",
      "install": "git clone https://github.com/zsh-users/zsh-autosuggestions ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/zsh-autosuggestions"
    },
    "zsh-syntax-highlighting": {
      "source": "https://github.com/zsh-users/zsh-syntax-highlighting",
      "install": "git clone https://github.com/zsh-users/zsh-syntax-highlighting ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting"
    },
    "zsh-completions": {
      "source": "https://github.com/zsh-users/zsh-completions",
      "install": "git clone https://github.com/zsh-users/zsh-completions ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/zsh-completions"
    },
    "git": {
      "source": "builtin",
      "install": "# plugin nativo do Oh My Zsh, nada a instalar"
    }
  },

  "omz_themes": {
    "dracula-pro": {
      "source": "https://draculatheme.com/pro",
      "manual": true,
      "note": "Tema PRO (PAGO) da Dracula. NÃO está em repo público. Você precisa baixar do seu acesso comprado em draculatheme.com/pro e copiar o arquivo .zsh-theme para ${ZSH_CUSTOM}/themes/. A versão gratuita equivalente é 'dracula' (git clone https://github.com/dracula/zsh). O Claude deve PERGUNTAR qual você quer usar na máquina nova."
    },
    "dracula": {
      "source": "https://github.com/dracula/zsh",
      "install": "git clone https://github.com/dracula/zsh.git ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/dracula-clone && ln -sf ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/dracula-clone/dracula.zsh-theme ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/dracula.zsh-theme"
    },
    "spaceship": {
      "source": "https://github.com/spaceship-prompt/spaceship-prompt",
      "install": "git clone https://github.com/spaceship-prompt/spaceship-prompt.git ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/spaceship-prompt --depth=1 && ln -sf ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/spaceship-prompt/spaceship.zsh-theme ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/spaceship.zsh-theme"
    }
  },

  "frameworks": {
    "oh-my-zsh": {
      "detect_path": "~/.oh-my-zsh",
      "source": "https://github.com/ohmyzsh/ohmyzsh",
      "install": "sh -c \"$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)\" \"\" --unattended",
      "note": "Instalar PRIMEIRO, antes de plugins e temas (eles vão para dentro de ~/.oh-my-zsh/custom)."
    }
  },

  "version_managers": {
    "nvm": {
      "detect_path": "~/.nvm",
      "source": "https://github.com/nvm-sh/nvm",
      "verify": "nvm --version  # rodar em shell interativa, após carregar o nvm",
      "install": "curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash"
    },
    "pyenv": {
      "detect_path": "~/.pyenv",
      "detect": "pyenv",
      "source": "https://github.com/pyenv/pyenv",
      "verify": "pyenv --version",
      "install": {
        "macos": "brew install pyenv",
        "debian": "curl -fsSL https://pyenv.run | bash"
      }
    },
    "bun": {
      "detect_path": "~/.bun",
      "detect": "bun",
      "source": "https://bun.sh",
      "verify": "bun --version",
      "install": "curl -fsSL https://bun.sh/install | bash"
    },
    "pnpm": {
      "detect": "pnpm",
      "source": "https://pnpm.io",
      "verify": "pnpm --version",
      "install": {
        "macos": "brew install pnpm",
        "fallback": "curl -fsSL https://get.pnpm.io/install.sh | sh -"
      }
    },
    "go": {
      "detect": "go",
      "source": "https://go.dev/dl/",
      "verify": "go version",
      "install": {
        "macos": "brew install go",
        "debian": "sudo apt install -y golang-go"
      }
    }
  },

  "platform_specific_patterns": {
    "_comment": "Trechos no .zshrc específicos de UMA plataforma. Cada grupo é rotulado pela plataforma de origem. No destino, removem-se as linhas cuja plataforma NÃO corresponde ao SO de lá. Funciona nos dois sentidos (WSL→Mac e Mac→WSL).",
    "wsl_windows": [
      "/mnt/c",
      "/mnt/wslg",
      "MESA_D3D12",
      "PULSE_SERVER",
      "WARP_ENABLE_WAYLAND",
      "wslpath",
      "powershell.exe",
      "SourcedRcFileForWarp",
      "WarpTerminal",
      "VSCODE_BIN",
      "nice-vscode",
      "pastepng",
      "pscreen"
    ],
    "macos": [
      "/opt/homebrew",
      "brew shellenv",
      "pbcopy",
      "pbpaste",
      "osascript",
      "open -a",
      "defaults write",
      "defaults read",
      "/usr/libexec/java_home",
      "/Users/",
      "ls -G",
      "LSCOLORS",
      "/Applications/",
      "iTerm",
      "com.apple."
    ],
    "debian_binary_rename": {
      "_comment": "Aliases que existem só por causa de binários renomeados no Debian/Ubuntu (bat→batcat, fd→fdfind). No DESTINO: manter/adicionar se for Debian; remover se for macOS/outros.",
      "patterns": ["alias bat=\"batcat\"", "alias fd=\"fdfind\"", "batcat", "fdfind"]
    }
  }
}
